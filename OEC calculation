s_curve_int <- function(year0, y0, year1, y1, k = 10, midpoint = NULL) {
  if (is.null(midpoint)) {
    midpoint <- (year0 + year1) / 2
  }
  tibble(
    xx = seq(year0, year1, by = 1)
  ) %>%
    mutate(
      t = (xx - midpoint) / (year1 - year0),
      s = 1 / (1 + exp(-k * t)),
      yy = y0 + (s - min(s)) / (max(s) - min(s)) * (y1 - y0)
    )
}


