library(tidyverse)
library(collapse)

read_csv("./building/energy_conservation/CE_tm_EtoU_low.csv") -> bud
read_csv("./transportation/baseline/CE_tm_EtoU.csv") -> tra
read_csv("./power/baseline/CE_tm_EtoU.csv") -> pwr

bud %>% 
  mutate(ssp1=ssp, city1=city, year1=year) %>% 
  unite("link", ssp1, city1, year1) %>%
  dplyr::select(link, sce, ord, ssp, city, year) %>% 
  unique() -> nms

bud %>% 
  mutate(link = paste(ssp, city, year, sep = "_")) -> bud1 
fsummarise(
  fgroup_by(bud1, link),
  across(c(ce_Extraction, ce_Manufacturing, ce_Transportation, ce_Operational, ce_emb, ce_opt, ce_total), fsum)
) %>% 
  rename(bud_Extraction=ce_Extraction, 
         bud_Manufacturing=ce_Manufacturing, 
         bud_Transportation=ce_Transportation, 
         bud_Operational=ce_Operational, 
         
         bud_emb=ce_emb, 
         bud_opt=ce_opt, 
         bud_total=ce_total) -> bud3

tra %>% 
  mutate(link = paste(ssp, city, year, sep = "_")) -> tra1 
fsummarise(
  fgroup_by(tra1, link),
  across(c(ce_Extraction, ce_Manufacturing, ce_Transportation, ce_Operational, ce_emb, ce_opt, ce_total), fsum)
) %>% 
  rename(tra_Extraction=ce_Extraction, 
         tra_Manufacturing=ce_Manufacturing, 
         tra_Transportation=ce_Transportation, 
         tra_Operational=ce_Operational, 
         
         tra_emb=ce_emb, 
         tra_opt=ce_opt, 
         tra_total=ce_total) -> tra3

pwr %>% 
  mutate(link = paste(ssp, city, year, sep = "_")) -> pwr1 
fsummarise(
  fgroup_by(pwr1, link),
