ppp_up <- function(df, col_id) {
  col_nm <- names(df)[col_id]
  df %>%
    select(link, prod, !!sym(col_nm)) %>%
    rename(bs = !!sym(col_nm)) %>%
    pivot_wider(names_from = prod, values_from = bs) %>%
    mutate(
      b2 = b2 + (b1 * 0.1) / 4,
      b3 = b3 + (b1 * 0.1) / 4,
      b4 = b4 + (b1 * 0.1) / 4,
      b5 = b5 + (b1 * 0.1) / 4,
      b1 = b1 * 0.9
    ) %>%
    pivot_longer(-link, names_to = "prod", values_to = col_nm) %>%
    mutate(
      !!sym(col_nm) := if_else(.data[[col_nm]] < 0, 0, .data[[col_nm]])
    )
}

res_up <- map(
  3:ncol(emb_tmp0),
  ~ ppp_up(emb_tmp0, .x)
)

emb_up1 <- reduce(
  res_up,
  left_join,
  by = c("link", "prod")
)

ppp_down <- function(df, col_id) {
  col_nm <- names(df)[col_id]
  df %>%
    select(link, prod, !!sym(col_nm)) %>%
    rename(bs = !!sym(col_nm)) %>%
    pivot_wider(names_from = prod, values_from = bs) %>%
    mutate(b2=b2-(b1*0.1)/4,
           b3=b3-(b1*0.1)/4,
           b4=b4-(b1*0.1)/4,
           b5=b5-(b1*0.1)/4,
           b1=b1*1.1) %>% 
    pivot_longer(-link, names_to = "prod", values_to = col_nm) %>%
    mutate(
      !!sym(col_nm) := if_else(.data[[col_nm]] < 0, 0, .data[[col_nm]])
    )
}

