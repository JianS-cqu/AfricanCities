js_life <- function(acode) {
  
  read_csv(paste0("./life_sensitivity/",acode,".csv")) -> df
  acode %>% 
    as_tibble() %>% 
    separate(value, into = c("ss","sce","ord","bb","aa"), sep = "_") %>% 
    left_join(nn1) %>% 
    left_join(nn2) %>% 
    dplyr::select(-aa, -bb) -> acode0
  acode0$sce -> sce11
  acode0$ord -> ord11
  acode0 %>% 
    mutate(ss="CE") %>% 
    mutate(xx="lifetm") %>% 
    unite("link",ss, sce, ord,xx, aa1,bb1) %>% 
    pull() -> acode2
  
  eng %>% 
    left_join(fat) %>% 
    separate(link, into = c("ISO", "sce", "ord", "year", "prod"), sep = "_") %>% 
    dplyr::filter(sce==sce11) %>% 
    dplyr::filter(ord==ord11) %>% 
    dplyr::select(-sce, -ord) %>% 
    unite("link", ISO, year, prod) -> fff
  
  df %>% 
    dplyr::select(sce, ord, ssp, city, year, ms, prod) %>% 
    mutate(hhh=case_when(
      prod=="b1"~3,
      prod=="b2"~3,
      prod=="b3"~3,
      prod=="b4"~3.5,
      prod=="b5"~5
    )) %>% 
    mutate(bs=ms/hhh) %>% 
    dplyr::select(-ms, -hhh) %>% 
    left_join(nms) %>% 
    mutate(year1=year, prod1=prod) %>% 
    unite("link", ISO, year1, prod1) %>% 
    left_join(fff) %>% 
    mutate(ce_Operational=bs*(eng_e*fat_ele+eng_f*fat_noe)) %>% 
    dplyr::select(sce, ord, ssp, city, year, prod, ce_Operational) %>% 
    mutate(ssp0=ssp, city0=city, year0=year, prod0=prod) %>% 
    unite("link", ssp0, city0, year0, prod0) %>% 
    mutate(ce_opt=ce_Operational)-> ooo
  
  df %>% 
    dplyr::select(-ou, -inflow2) %>% 
    left_join(cof) %>% 
    mutate(
      in_Steel=inflow3*Steel/1000,
      in_Aluminum=inflow3*Aluminum/1000,
      in_Copper=inflow3*Copper/1000,
      in_Cement=inflow3*Cement/1000,
      in_Sand=inflow3*Sand/1000,
      in_Gravel=inflow3*Gravel/1000,
      in_Glass=inflow3*Glass/1000,
      in_Brick=inflow3*Brick/1000,
      in_Wood=inflow3*Wood/1000,
      in_Asphalt=inflow3*Asphalt/1000,
      in_Plastic=inflow3*Plastic/1000,
      in_Rubber=inflow3*Rubber/1000
    ) %>% 
    dplyr::select(-c(6:8)) %>%    
    dplyr::select(-c(7:18)) %>% 
    left_join(ccc1) %>% 
    mutate(
      ce_Extraction=in_Steel*Steel_Extraction/1000+in_Aluminum*Aluminum_Extraction/1000+in_Copper*Copper_Extraction/1000+in_Cement*Cement_Extraction/1000+in_Sand*Sand_Extraction/1000+in_Gravel*Gravel_Extraction/1000+in_Glass*Glass_Extraction/1000+in_Brick*Brick_Extraction/1000+in_Wood*Wood_Extraction/1000+in_Asphalt*Asphalt_Extraction/1000+in_Plastic*Plastic_Extraction/1000+in_Rubber*Rubber_Extraction/1000,
      ce_Manufacturing=in_Steel*Steel_Manufacturing/1000+in_Aluminum*Aluminum_Manufacturing/1000+in_Copper*Copper_Manufacturing/1000+in_Cement*Cement_Manufacturing/1000+in_Sand*Sand_Manufacturing/1000+in_Gravel*Gravel_Manufacturing/1000+in_Glass*Glass_Manufacturing/1000+in_Brick*Brick_Manufacturing/1000+in_Wood*Wood_Manufacturing/1000+in_Asphalt*Asphalt_Manufacturing/1000+in_Plastic*Plastic_Manufacturing/1000+in_Rubber*Rubber_Manufacturing/1000,
      ce_Transportation=in_Steel*Steel_Transportation/1000+in_Aluminum*Aluminum_Transportation/1000+in_Copper*Copper_Transportation/1000+in_Cement*Cement_Transportation/1000+in_Sand*Sand_Transportation/1000+in_Gravel*Gravel_Transportation/1000+in_Glass*Glass_Transportation/1000+in_Brick*Brick_Transportation/1000+in_Wood*Wood_Transportation/1000+in_Asphalt*Asphalt_Transportation/1000+in_Plastic*Plastic_Transportation/1000+in_Rubber*Rubber_Transportation/1000,
      ce_emb=ce_Extraction+ce_Manufacturing+ce_Transportation
    ) %>% 
    dplyr::select(-c(7:42)) %>% 
    unite("link", ssp, city, year, prod) %>% 
    dplyr::select(link, ce_Extraction, ce_Manufacturing, ce_Transportation, ce_emb) %>% 
    left_join(ooo) %>% 
    mutate(ce_total=ce_opt+ce_emb) %>% 
    dplyr::select(-link) %>% 
    write_csv(paste0("./sensi/",acode2,".csv"))
  
}


