    for (i in 1:j) {
      result[i] <- as.numeric(ms[i, "input"]) * dnorm(j-i, mean = 11, sd = 5.5)  ##change
    }
    ms[j,"ou"] <- sum(result)
    ms[j+1,"input"] <- ms[j+1,"ms"]-ms[j,"ms"]+ms[j,"ou"]
    if(ms[j,"input"] < 0)
    { 
      ms[j-1,"ou"] <- ms[j-1,"ou"]-ms[j,"input"]
      ms[j,"input"] <- 0 
    }
  }
  ms %>% 
    na.omit() %>% 
    mutate(inflow2=if_else(input == 0, ou, input))
  
}


