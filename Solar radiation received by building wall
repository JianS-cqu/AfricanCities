afc_cc_fixed <- function(acode, cita) {
  df %>%
    dplyr::filter(city == acode) %>%
    mutate(
      fwj1 = cita,                  
      lat_rad = latt * pi / 180,
      zenith_rad = zenith * pi / 180,
      dem_km = dem / 1000,
      nn2 = nn2,
      Gon = 1367 * (1 + 0.033 * cos(2 * pi * nn2 / 365)),
      decl_rad = (23.45 * sin(2 * pi * (284 + nn2) / 365)) * pi / 180,
      tb = 0.4237 - 0.00821 * (6 - dem_km)^2 +
        (0.5055 + 0.00595 * (6.5 - dem_km)^2) * exp(-(0.2711 + 0.01858 * (2.5 - dem_km)^2) / pmax(cos(zenith_rad), 1e-8)),
      td = 0.271 - 0.294 * tb
    ) %>%
    mutate(
      H_rad = (time_hrs - 12) * 15 * pi / 180 
    ) %>%
    mutate(
      s_x = cos(decl_rad) * sin(H_rad), 
      s_y = cos(decl_rad) * cos(H_rad) * sin(lat_rad) - sin(decl_rad) * cos(lat_rad),
      s_z = cos(decl_rad) * cos(H_rad) * cos(lat_rad) + sin(decl_rad) * sin(lat_rad)
    ) %>%
    mutate(
      gamma_f = fwj1 * pi / 180,  
      beta = pi / 2 
    ) %>%
    mutate(
      n_x = sin(beta) * sin(gamma_f),  
      n_y = sin(beta) * cos(gamma_f), 
      n_z = cos(beta) 
    ) %>%
    mutate(
      cos_inc = s_x * n_x + s_y * n_y + s_z * n_z,
      cos_zenith = s_z,  
      cos_inc_pos = pmax(0, cos_inc),
      cos_zenith_pos = pmax(cos_zenith, 1e-12),
      Rb = if_else(cos_zenith > 0 & cos_inc > 0, cos_inc_pos / cos_zenith_pos, 0),
      Hb = Gon * tb * cos_zenith,
      Hd = Gon * td * cos_zenith,
      Hdg = 0.2 * 0.5 * (Hb + Hd),
      Ht_inst = Hb * Rb + Hd * 2/3 + Hdg
    ) %>%
    summarise(Ht_total = sum(pmax(Ht_inst, 0), na.rm = TRUE)) %>% 
    pull(Ht_total)
}


