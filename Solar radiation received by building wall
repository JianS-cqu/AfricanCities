library(tidyverse)

read_csv("AFCC/new20205/data/sun_Ht0.csv") %>% 
  mutate(rr=if_else(rr==0,0.000000001,rr)) -> dfn

js_solar <- function(ccode) {
  read_csv(paste0("AFCC/new20205/rstt/ac_",ccode,"/z_",ccode,".csv")) %>% 
    mutate(acode=ccode) %>% 
    dplyr::select(acode, cita=cita111, area=area_m2) %>% 
    mutate(cita=round(cita, digits = 0))-> btv
  dfn %>% 
    dplyr::filter(acode==ccode) %>% 
    dplyr::select(cita, rr) -> jpp
  btv %>% 
    left_join(jpp) %>% 
    mutate(part1 = area*0.2,
           part2 = area - part1) %>% 
    mutate(js_part1= (1-rr)* part1) %>% 
    mutate(total1=(js_part1+part2)) -> lgy3
  (sum(lgy3$total1)/sum(lgy3$area)) -> rd_low
  btv %>% 
    left_join(jpp) %>% 
    mutate(part1 = area*0.4,
           part2 = area - part1) %>% 
    mutate(js_part1= (1-rr)* part1) %>% 
    mutate(total1=(js_part1+part2)) -> lgy6
  (sum(lgy6$total1)/sum(lgy6$area)) -> rd_high
  
  tibble(rd_low, rd_high) %>% 
    mutate(city=ccode) %>% 
    write_csv(paste0("AFCC/new20205/ztmp_sun/ss_",ccode,".csv"))
  
}


