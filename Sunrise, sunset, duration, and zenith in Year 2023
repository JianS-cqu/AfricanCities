###Operational emission calculation

library(tidyverse)

##tm_EtoU

read_csv("AFCC/new20205/data/opt_EnergyConsumption_perArea.csv") %>% 
  unite("link", ISO, sce, ord, year, prod) %>% 
  spread(type, eng_area) %>% 
  rename(eng_e=e, eng_f=f) -> eng
read_csv("AFCC/new20205/data/opt_electricFactor_tCO2GJ.csv") %>% 
  unite("link", ISO, sce, ord, year, prod) %>% 
  spread(type, e_fac) %>% 
  rename(fat_ele=ele, fat_noe=noe) -> fat
eng %>% 
  left_join(fat) %>% 
  separate(link, into = c("ISO", "sce", "ord", "year", "prod"), sep = "_") %>% 
  dplyr::filter(sce=="tm") %>% 
  dplyr::filter(ord=="EtoU") %>% 
  dplyr::select(-sce, -ord) %>% 
  unite("link", ISO, year, prod) -> fff


read_csv("AFCC/new20205/data/building/baseline/Bs_tm_EtoU.csv") %>% 
  dplyr::select(sce, ord, ssp, city, year, ms, prod) %>% 
  mutate(hhh=case_when(
    prod=="b1"~3,
    prod=="b2"~3,
    prod=="b3"~3,
    prod=="b4"~3.5,
    prod=="b5"~5
  )) %>% 
  mutate(bs=ms/hhh) %>% 
  dplyr::select(-ms, -hhh) -> df
read_csv("AFCC/new20205/shp/afc_nms333.csv") %>% 
  dplyr::select(city, ISO=ISO3) -> nms
df %>% 
  left_join(nms) %>% 
  mutate(year1=year, prod1=prod) %>% 
  unite("link", ISO, year1, prod1) %>% 
  left_join(fff) %>% 
  mutate(ce_Operational=bs*(eng_e*fat_ele+eng_f*fat_noe)) %>% 
  dplyr::select(sce, ord, ssp, city, year, prod, ce_Operational) %>% 
  write_csv("AFCC/new20205/data/building/baseline/CE_Opt_tm_EtoU.csv")



